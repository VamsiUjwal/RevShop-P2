                    <div class="col-md-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Subtotal</span>
                            <span class="text-dark fw-bold" th:text="'Rs.' + ${order.totalAmount}">Rs.0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Shipping</span>
                            <span class="text-success fw-bold">FREE</span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-3 mt-3 total-row">
                            <span>Total Paid</span>
                            <span th:text="'Rs.' + ${order.totalAmount}">Rs.0.00</span>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-5 border-top">
                    <div class="row align-items-center">
                        <div class="col-6">
                            <h6 class="text-secondary text-uppercase small mb-2">Payment Details</h6>
                            <p class="mb-1">Method: <strong th:text="${order.payment.paymentMethod}">Credit
                                    Card</strong></p>
                            <p class="mb-0" th:if="${order.payment.transactionId}">Transaction: <span
                                    class="text-secondary small" th:text="${order.payment.transactionId}">TXN-123</span>
                            </p>
                        </div>
                        <div class="col-6 text-end">
                            <p class="text-secondary small mb-0">Thank you for shopping with RevShop!</p>
                            <p class="fw-bold text-primary mb-0">www.revshop.com</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>

</html>"
